# learnEnglish — Configuration
# Copier ce fichier en .env et adapter

DATABASE_URL=postgresql+asyncpg://learnenglish:learnenglish@localhost:5432/learnenglish
SECRET_KEY=change-me-to-a-long-random-string-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM (DeepSeek)
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.7

# Image API (optionnel, Phase 6)
IMAGE_API_PROVIDER=openai
IMAGE_API_KEY=
IMAGE_API_MODEL=dall-e-3
IMAGE_OUTPUT_DIR=

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=2
LOG_LEVEL=info

# Feature flags
ENABLE_AI=false
CACHE_ENABLED=false
REDIS_URL=redis://localhost:6379/0
